---
import Layout from '../layouts/Layout.astro';
import FadeUp from '../components/animations/FadeUp.astro';

const services = [
  {
    title: "Brand Identity",
    description: "We craft visual stories that resonate. From logo design to comprehensive brand guidelines that define your presence in the market.",
    features: ["Visual Strategy", "Logo Design", "Brand Guidelines", "Typography Systems"]
  },
  {
    title: "Digital Experience",
    description: "Designing interfaces that aren't just beautiful, but functional. We focus on UX/UI that converts and delights users.",
    features: ["Web Design", "Mobile Apps", "Design Systems", "Prototyping"]
  },
  {
    title: "Technical Execution",
    description: "High-performance code is the backbone of great design. We build scalable, fast, and secure digital products.",
    features: ["Astro & Next.js", "Full-stack Dev", "API Integration", "Performance Audit"]
  },
  {
    title: "Strategic Growth",
    description: "Data-driven strategies to help your brand scale. We identify opportunities and execute growth loops.",
    features: ["SEO Strategy", "Market Analysis", "Conversion Rate Optimization", "Content Strategy"]
  }
];
---

<Layout 
  title="Branding, Web Design & Digital Strategy"
  description="Brand identity, UX/UI design, full-stack development, and strategic growth - four service pillars for brands ready to stand out and scale."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "@id": "https://innovate-proto.vercel.app/services#webpage",
          "url": "https://innovate-proto.vercel.app/services",
          "name": "Branding, Web Design & Digital Strategy",
          "description": "Brand identity, UX/UI design, full-stack development, and strategic growth.",
          "provider": { "@id": "https://innovate-proto.vercel.app/#organization" },
          "breadcrumb": { "@id": "https://innovate-proto.vercel.app/services#breadcrumb" }
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://innovate-proto.vercel.app/services#breadcrumb",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://innovate-proto.vercel.app/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Services",
              "item": "https://innovate-proto.vercel.app/services"
            }
          ]
        },
        {
          "@type": "OfferCatalog",
          "@id": "https://innovate-proto.vercel.app/services#catalog",
          "name": "Digital Services",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Brand Identity"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Digital Experience"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Technical Execution"
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Strategic Growth"
              }
            }
          ]
        }
      ]
    }
    </script>
  </Fragment>

  <section class="py-20 md:py-32 px-6 md:px-24">
    <FadeUp nojs={true}>
      <h1 class="text-[clamp(3.5rem,10vw,12rem)] font-black tracking-[-0.05em] mb-12 leading-[0.8] uppercase">OUR <br /> SERVICES.</h1>
      <p class="text-xl md:text-3xl text-neutral-500 max-w-3xl leading-relaxed">
        We specialize in creating bespoke digital solutions that bridge the gap between human needs and business goals. Our multidisciplinary approach ensures that your brand doesn't just look premium, but performs with technical excellence at every touchpoint.
      </p>
    </FadeUp>
  </section>

  <section class="py-20 md:py-32 px-6 md:px-24 bg-white/50 backdrop-blur-sm border-t border-neutral-100">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16">
      {services.map((service) => (
        <FadeUp class="p-8 md:p-14 bg-white border border-neutral-100 rounded-[2.5rem] hover:border-black transition-all duration-700 group hover:shadow-[0_40px_80px_-20px_rgba(0,0,0,0.05)] cursor-pointer" data-cursor="explore">
          <div class="mb-10 w-12 h-12 md:w-16 md:h-16 bg-neutral-50 rounded-2xl flex items-center justify-center group-hover:bg-black group-hover:text-white transition-colors duration-500">
             <span class="text-xl md:text-2xl font-bold">0{services.indexOf(service) + 1}</span>
          </div>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-8">{service.title}</h2>
          <p class="text-base md:text-lg text-neutral-500 mb-12 leading-relaxed max-w-md">{service.description}</p>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-5 pt-8 border-t border-neutral-50">
            {service.features.map((feature) => (
              <li class="flex items-center gap-3 text-sm font-bold text-neutral-800 uppercase tracking-wider">
                <span class="h-2 w-2 rounded-full bg-black/20 group-hover:bg-black transition-colors"></span>
                {feature}
              </li>
            ))}
          </ul>
        </FadeUp>
      ))}
    </div>
  </section>

  <!-- How We Work Section -->
  <section class="py-20 md:py-40 px-6 md:px-24 bg-[#fafafa]">
    <div class="max-w-4xl mb-24">
      <FadeUp>
        <h2 class="text-4xl md:text-7xl font-bold tracking-tight mb-12 uppercase leading-[0.9]">HOW WE <br /> WORK.</h2>
        <p class="text-xl text-neutral-500 leading-relaxed">
          Our process is rigorous, transparent, and built for scale. We don't believe in "throwing things over the fence." We work as a technical partner, deeply embedded in your business goals.
        </p>
      </FadeUp>
    </div>

    <div class="space-y-16">
      <FadeUp delay={0.1}>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start py-12 border-t border-neutral-200">
          <div class="md:col-span-1 text-2xl font-bold text-neutral-300">01</div>
          <div class="md:col-span-4 text-3xl font-bold tracking-tight">Discovery & Audit</div>
          <div class="md:col-span-7 text-lg text-neutral-500 leading-relaxed">
            We start by understanding your market, your competitors, and your technical debt. We perform a deep SEO and UX audit to identify quick wins and long-term opportunities. This ensures our strategy is rooted in data, not assumptions.
          </div>
        </div>
      </FadeUp>
      <FadeUp delay={0.2}>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start py-12 border-t border-neutral-200">
          <div class="md:col-span-1 text-2xl font-bold text-neutral-300">02</div>
          <div class="md:col-span-4 text-3xl font-bold tracking-tight">Strategic Blueprint</div>
          <div class="md:col-span-7 text-lg text-neutral-500 leading-relaxed">
            We define the brand voice, the visual language, and the technical architecture. This isn't just a design mockup; it's a comprehensive roadmap for how your brand will exist and grow in the digital space over the next 3-5 years.
          </div>
        </div>
      </FadeUp>
      <FadeUp delay={0.3}>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start py-12 border-t border-neutral-200">
          <div class="md:col-span-1 text-2xl font-bold text-neutral-300">03</div>
          <div class="md:col-span-4 text-3xl font-bold tracking-tight">Design & Prototyping</div>
          <div class="md:col-span-7 text-lg text-neutral-500 leading-relaxed">
            Our designers create high-fidelity prototypes that allow you to feel the product before a single line of production code is written. We focus on micro-interactions, accessibility, and high-end aesthetics that reflect your premium positioning.
          </div>
        </div>
      </FadeUp>
      <FadeUp delay={0.4}>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start py-12 border-t border-neutral-200">
          <div class="md:col-span-1 text-2xl font-bold text-neutral-300">04</div>
          <div class="md:col-span-4 text-3xl font-bold tracking-tight">Technical Execution</div>
          <div class="md:col-span-7 text-lg text-neutral-500 leading-relaxed">
            Using modern frameworks like Astro and Next.js, our developers build lightning-fast, SEO-optimized platforms. We prioritize Core Web Vitals from day one, ensuring your site isn't just beautiful, but also a top-performer in search rankings.
          </div>
        </div>
      </FadeUp>
    </div>
  </section>

  <!-- Pricing/Engagement Section -->
  <section class="py-20 md:py-32 px-6 md:px-24 bg-white">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
      <div>
        <FadeUp>
          <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-8">ENGAGEMENT MODELS.</h2>
          <p class="text-lg text-neutral-500 mb-12 leading-relaxed">
            We work with a limited number of clients at any given time to ensure maximum quality and focus. Our engagement models are tailored to your growth stage.
          </p>
          <div class="space-y-8">
            <div class="flex gap-6">
              <div class="h-12 w-12 rounded-full bg-neutral-50 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h4 class="font-bold text-xl mb-2">Project Based</h4>
                <p class="text-neutral-500">Ideal for full rebranding, new product launches, or complex web platform development. Fixed scope and timeline.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="h-12 w-12 rounded-full bg-neutral-50 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.5 8.5 0 0 1 4.6 1.3L21 4.5l-2.2 4.6 2.2 2.4z"/></svg>
              </div>
              <div>
                <h4 class="font-bold text-xl mb-2">Agency Retainer</h4>
                <p class="text-neutral-500">For high-growth startups needing ongoing design and technical support to scale their digital ecosystem.</p>
              </div>
            </div>
          </div>
        </FadeUp>
      </div>
      <div class="bg-black text-white p-12 md:p-20 rounded-[3rem] text-center">
        <FadeUp delay={0.2}>
          <h3 class="text-3xl md:text-5xl font-bold mb-8">START THE CONVERSATION.</h3>
          <p class="text-neutral-400 mb-12">Book a 30-minute discovery call to discuss your project requirements and get a custom quote.</p>
          <a href="/contact" class="inline-block px-12 py-6 bg-white text-black rounded-full font-bold text-xl hover:scale-105 transition-transform">Book a Consultation</a>
        </FadeUp>
      </div>
    </div>
  </section>
</Layout>
