---
import Layout from '../layouts/Layout.astro';
import FadeUp from '../components/animations/FadeUp';

const services = [
  {
    title: "Brand Identity",
    description: "We craft visual stories that resonate. From logo design to comprehensive brand guidelines that define your presence in the market.",
    features: ["Visual Strategy", "Logo Design", "Brand Guidelines", "Typography Systems"]
  },
  {
    title: "Digital Experience",
    description: "Designing interfaces that aren't just beautiful, but functional. We focus on UX/UI that converts and delights users.",
    features: ["Web Design", "Mobile Apps", "Design Systems", "Prototyping"]
  },
  {
    title: "Technical Execution",
    description: "High-performance code is the backbone of great design. We build scalable, fast, and secure digital products.",
    features: ["Astro & Next.js", "Full-stack Dev", "API Integration", "Performance Audit"]
  },
  {
    title: "Strategic Growth",
    description: "Data-driven strategies to help your brand scale. We identify opportunities and execute growth loops.",
    features: ["SEO Strategy", "Market Analysis", "Conversion Rate Optimization", "Content Strategy"]
  }
];
---

<Layout title="Our Services">
  <section class="py-20 md:py-32 px-6 md:px-24">
    <FadeUp client:load>
      <h1 class="text-5xl md:text-9xl font-extrabold tracking-tighter mb-12">OUR <br /> SERVICES.</h1>
      <p class="text-xl md:text-3xl text-neutral-500 max-w-3xl leading-relaxed">
        We specialize in creating bespoke digital solutions that bridge the gap between human needs and business goals.
      </p>
    </FadeUp>
  </section>

  <section class="py-20 md:py-32 px-6 md:px-24 bg-white border-t border-neutral-100">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      {services.map((service) => (
        <FadeUp client:visible className="p-12 border border-neutral-100 rounded-3xl hover:border-black transition-all group">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">{service.title}</h2>
          <p class="text-lg text-neutral-500 mb-10 leading-relaxed">{service.description}</p>
          <ul class="grid grid-cols-2 gap-4">
            {service.features.map((feature) => (
              <li class="flex items-center gap-2 text-sm font-medium text-neutral-700">
                <span class="h-1.5 w-1.5 rounded-full bg-black"></span>
                {feature}
              </li>
            ))}
          </ul>
        </FadeUp>
      ))}
    </div>
  </section>

  <section class="py-20 md:py-32 px-6 md:px-24 bg-black text-white">
    <FadeUp client:visible>
      <div class="max-w-4xl">
        <h2 class="text-5xl md:text-7xl font-bold tracking-tight mb-12">NEED A CUSTOM SOLUTION?</h2>
        <p class="text-xl text-neutral-400 mb-12">Every brand is unique. We don't believe in one-size-fits-all. Let's discuss your specific needs.</p>
        <a href="/contact" class="inline-block px-12 py-6 bg-white text-black rounded-full font-bold text-xl hover:scale-105 transition-transform">Get Started</a>
      </div>
    </FadeUp>
  </section>
</Layout>
