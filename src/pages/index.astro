---
import Layout from '../layouts/Layout.astro';
import FadeUp from '../components/animations/FadeUp.astro';
import WorkSlider from '../components/home/WorkSlider';
import TestimonialSlider from '../components/home/TestimonialSlider';

const caseStudies = [
  {
    id: 1,
    title: "Zenith Banking",
    category: "Fintech / UX Design",
    description: "A complete digital overhaul for a legacy financial institution, focusing on mobile-first banking and glassmorphic UI.",
    image: "https://images.unsplash.com/photo-1563986768609-322da13575f3?q=80&w=2070&auto=format&fit=crop",
    link: "/work/zenith-banking"
  },
  {
    id: 2,
    title: "Project Alpha",
    category: "Branding & Strategy",
    description: "A complete visual identity overhaul for a leading tech pioneer.",
    image: "https://images.unsplash.com/photo-1614850523296-d8c1af93d400?q=80&w=2070&auto=format&fit=crop",
    link: "/work"
  },
  {
    id: 3,
    title: "Lumina Web",
    category: "Web Development",
    description: "High-performance marketing site with interactive storytelling.",
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2015&auto=format&fit=crop",
    link: "/work"
  },
  {
    id: 4,
    title: "Aura Commerce",
    category: "E-Commerce",
    description: "A seamless shopping experience for a luxury fashion house.",
    image: "https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=2070&auto=format&fit=crop",
    link: "/work"
  }
];

const testimonials = [
  {
    id: 1,
    title: "Outstanding Innovation",
    category: "Elena S., CEO at Vercel",
    description: "Innovate transformed our digital presence. Their attention to detail and creative vision is unmatched in the industry.",
  },
  {
    id: 2,
    title: "Game Changing Partner",
    category: "Marcus R., Head of Design at Stripe",
    description: "Working with Innovate was the best decision for our rebranding. They don't just design; they think strategically.",
  },
  {
    id: 3,
    title: "Technical Excellence",
    category: "Adrian L., CTO at Linear",
    description: "The team at Innovate delivered a high-performance web experience that significantly improved our conversion rates.",
  }
];

const homeSections = [
  {
    title: "Our Expertise",
    description: "We provide comprehensive digital solutions that drive growth and inspire change. From strategic branding to high-performance development.",
    link: "/services",
    linkText: "Explore Services",
    image: "https://images.unsplash.com/photo-1497215728101-856f4ea42174?q=80&w=2070&auto=format&fit=crop"
  },
  {
    title: "Who We Are",
    description: "A collective of designers, thinkers, and makers dedicated to crafting beautiful and functional digital products.",
    link: "/about",
    linkText: "Meet the Team",
    image: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2070&auto=format&fit=crop"
  },
  {
    title: "Our Work",
    description: "Explore our latest projects where we've helped brands reach their full potential through innovative design and code.",
    link: "/work",
    linkText: "View Case Studies",
    image: "https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=2070&auto=format&fit=crop"
  }
];

const faqs = [
  {
    question: "How long does a typical project take?",
    answer: "Most branding and web projects range from 6 to 12 weeks depending on complexity. We focus on quality and strategic depth rather than rushing deliverables. Our process involves a deep dive into your brand strategy before we even begin the design phase, ensuring that every visual element serves a specific business purpose and resonates with your target audience."
  },
  {
    question: "Do you offer post-launch support?",
    answer: "Yes, we provide ongoing maintenance and performance optimization packages to ensure your platform remains fast and relevant. Beyond just technical updates, we monitor user behavior and conversion metrics to suggest iterative improvements, helping your brand stay ahead of the competition and adapt to changing market conditions."
  },
  {
    question: "What industries do you specialize in?",
    answer: "We primarily work with high-growth technology startups, financial services, and premium lifestyle brands that value design excellence. Our experience in these sectors allows us to bridge the gap between technical requirements and luxury aesthetics, creating high-performance digital products that don't just function perfectly but also convey a sense of premium quality and trust."
  }
];
---

<Layout 
  title="Digital Creative Agency for Tech & Fintech Brands"
  description="We craft high-performance branding, web design, and digital products for tech startups, fintech, and premium brands. Based in Singapore, working globally."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://innovate-proto.vercel.app/#website",
          "url": "https://innovate-proto.vercel.app/",
          "name": "Innovate",
          "publisher": {
            "@id": "https://innovate-proto.vercel.app/#organization"
          },
          "potentialAction": {
            "@type": "SearchAction",
            "target": "https://innovate-proto.vercel.app/search?q={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "How long does a typical project take?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Most branding and web projects range from 6 to 12 weeks depending on complexity. Our process involves a deep dive into your brand strategy before we even begin the design phase, ensuring that every visual element serves a specific business purpose and resonates with your target audience."
              }
            },
            {
              "@type": "Question",
              "name": "Does Innovate offer post-launch support?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes, Innovate provides ongoing maintenance and performance optimisation packages. Beyond just technical updates, we monitor user behavior and conversion metrics to suggest iterative improvements, helping your brand stay ahead of the competition."
              }
            },
            {
              "@type": "Question",
              "name": "What industries does Innovate specialise in?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Innovate primarily works with high-growth technology startups, financial services, and premium lifestyle brands. Our experience allows us to bridge the gap between technical requirements and luxury aesthetics."
              }
            }
          ]
        }
      ]
    }
    </script>
  </Fragment>

  <!-- Hero Section -->
  <section class="min-h-[85vh] md:min-h-[100vh] flex flex-col justify-center px-6 md:px-24 bg-[#fafafa] pt-32 md:pt-40 pb-32">
    <div class="max-w-4xl">
      <FadeUp nojs={true}>
        <span class="text-neutral-500 font-medium uppercase tracking-[0.2em] text-sm mb-6 block">Innovate Agency</span>
        <h1 class="text-[clamp(3.5rem,11vw,14rem)] font-black tracking-[-0.05em] text-black leading-[0.8] mb-8 uppercase">
          CRAFTING <br /> THE FUTURE <br /> OF DIGITAL.
        </h1>
        <p class="text-xl md:text-2xl text-neutral-600 max-w-xl leading-relaxed mb-10">
          We build high-performance experiences for brands that want to stand out and scale with elegance.
        </p>
        <div class="flex flex-col md:flex-row gap-4">
          <a href="/work" class="w-full md:w-auto px-8 py-4 bg-black text-white rounded-full font-medium hover:bg-neutral-800 transition-all text-center">View Our Work</a>
          <a href="/contact" class="w-full md:w-auto px-8 py-4 border border-neutral-200 rounded-full font-medium hover:bg-white hover:border-black transition-all text-center">Let's Talk</a>
        </div>
      </FadeUp>
    </div>
  </section>

  <!-- Summary Sections -->
  {homeSections.map((section, index) => (
    <section class="py-20 md:py-32 px-6 md:px-24 border-t border-neutral-100 bg-white overflow-hidden">
      <div class={`flex flex-col md:flex-row items-center gap-16 ${index % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
        <div class="w-full md:w-1/2">
          <FadeUp>
            <h2 class="text-[clamp(2.5rem,6vw,6rem)] font-black tracking-[-0.05em] mb-8 leading-[0.9] uppercase">{section.title}</h2>
            <p class="text-lg md:text-xl text-neutral-500 mb-10 max-w-lg leading-relaxed">{section.description}</p>
            <a href={section.link} class="group inline-flex items-center gap-2 text-lg font-bold border-b-2 border-black pb-1 hover:border-neutral-300 transition-all uppercase tracking-tighter">
              {section.linkText}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </FadeUp>
        </div>
        <div class="w-full md:w-1/2">
           <FadeUp delay={0.2}>
              <div class="aspect-[4/3] md:aspect-[4/5] overflow-hidden rounded-[2.5rem] bg-neutral-100" data-reveal="image" data-cursor="explore">
                <img src={section.image} alt={section.title} class="w-full h-full object-cover" loading="lazy" fetchpriority={index === 0 ? "high" : "auto"} width="800" height="1000" />
              </div>
           </FadeUp>
        </div>
      </div>
    </section>
  ))}

  <!-- Featured Case Studies -->
  <WorkSlider client:visible items={caseStudies} title="Featured Work" />

  <!-- Testimonials -->
  <TestimonialSlider client:visible items={testimonials} title="What Clients Say" />

  <!-- FAQ Section -->
  <section class="py-20 md:py-32 px-6 md:px-24 bg-[#fafafa]">
    <div class="max-w-4xl mx-auto">
      <FadeUp>
        <h2 class="text-4xl md:text-7xl font-bold tracking-tight mb-12 md:mb-16 text-center">FAQ</h2>
        <div class="space-y-6">
          {faqs.map((faq) => (
            <details class="group bg-white rounded-3xl border border-neutral-100 transition-all hover:border-neutral-200 overflow-hidden">
              <summary class="flex items-center justify-between p-6 md:p-8 cursor-pointer list-none">
                <h3 class="text-xl md:text-2xl font-bold tracking-tight">{faq.question}</h3>
                <div class="h-10 w-10 rounded-full bg-neutral-50 flex items-center justify-center transition-transform group-open:rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </summary>
              <div class="px-8 pb-8">
                <p class="text-neutral-500 text-lg leading-relaxed max-w-2xl">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </FadeUp>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="min-h-screen pt-40 pb-20 px-6 md:px-24 flex flex-col justify-center relative overflow-hidden bg-black text-white text-center" data-bgcolor="#000000">
    <div class="relative z-10">
      <FadeUp>
        <h2 class="text-[clamp(3rem,9vw,11rem)] font-black tracking-[-0.05em] mb-12 md:mb-20 uppercase leading-[0.8]">READY TO <br /> INNOVATE?</h2>
        <a href="/contact" class="inline-flex items-center justify-center h-24 w-24 md:h-40 md:w-40 rounded-full bg-white text-black font-bold text-lg md:text-2xl hover:scale-110 transition-transform duration-500 uppercase tracking-tighter">
          Start
        </a>
      </FadeUp>
    </div>
    {/* Decorative background text */}
    <div class="absolute inset-0 flex items-center justify-center opacity-5 pointer-events-none">
       <span class="text-[30vw] font-black leading-none">INNOVATE</span>
    </div>
  </section>
</Layout>
