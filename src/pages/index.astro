---
import Layout from '../layouts/Layout.astro';
import FadeUp from '../components/animations/FadeUp';
import WorkSlider from '../components/home/WorkSlider';
import TestimonialSlider from '../components/home/TestimonialSlider';

const caseStudies = [
  {
    id: 1,
    title: "Project Alpha",
    category: "Branding & Strategy",
    description: "A complete visual identity overhaul for a leading tech pioneer.",
    image: "https://images.unsplash.com/photo-1614850523296-d8c1af93d400?q=80&w=2070&auto=format&fit=crop"
  },
  {
    id: 2,
    title: "The Zenith App",
    category: "Mobile Design",
    description: "Designing the next generation of financial management.",
    image: "https://images.unsplash.com/photo-1551288049-bbbda536339a?q=80&w=2070&auto=format&fit=crop"
  },
  {
    id: 3,
    title: "Lumina Web",
    category: "Web Development",
    description: "High-performance marketing site with interactive storytelling.",
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2015&auto=format&fit=crop"
  },
  {
    id: 4,
    title: "Aura Commerce",
    category: "E-Commerce",
    description: "A seamless shopping experience for a luxury fashion house.",
    image: "https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=2070&auto=format&fit=crop"
  }
];

const testimonials = [
  {
    id: 1,
    title: "Outstanding Innovation",
    category: "Sarah Jenkins, CEO at Vercel",
    description: "Innovate transformed our digital presence. Their attention to detail and creative vision is unmatched in the industry.",
  },
  {
    id: 2,
    title: "Game Changing Partner",
    category: "Michael Chen, Head of Design at Stripe",
    description: "Working with Innovate was the best decision for our rebranding. They don't just design; they think strategically.",
  },
  {
    id: 3,
    title: "Technical Excellence",
    category: "David Miller, CTO at Linear",
    description: "The team at Innovate delivered a high-performance web experience that significantly improved our conversion rates.",
  }
];

const homeSections = [
  {
    title: "Our Expertise",
    description: "We provide comprehensive digital solutions that drive growth and inspire change. From strategic branding to high-performance development.",
    link: "/services",
    linkText: "Explore Services",
    image: "https://images.unsplash.com/photo-1497215728101-856f4ea42174?q=80&w=2070&auto=format&fit=crop"
  },
  {
    title: "Who We Are",
    description: "A collective of designers, thinkers, and makers dedicated to crafting beautiful and functional digital products.",
    link: "/about",
    linkText: "Meet the Team",
    image: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2070&auto=format&fit=crop"
  },
  {
    title: "Our Work",
    description: "Explore our latest projects where we've helped brands reach their full potential through innovative design and code.",
    link: "/work",
    linkText: "View Case Studies",
    image: "https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=2070&auto=format&fit=crop"
  }
];

const faqs = [
  {
    question: "How long does a typical project take?",
    answer: "Most branding and web projects range from 6 to 12 weeks depending on complexity. We focus on quality and strategic depth rather than rushing deliverables."
  },
  {
    question: "Do you offer post-launch support?",
    answer: "Yes, we provide ongoing maintenance and performance optimization packages to ensure your platform remains fast and relevant."
  },
  {
    question: "What industries do you specialize in?",
    answer: "We primarily work with high-growth technology startups, financial services, and premium lifestyle brands that value design excellence."
  }
];
---

<Layout title="Modern Digital Agency">
  <!-- Hero Section -->
  <section class="min-h-[90vh] flex flex-col justify-center px-6 md:px-24 bg-[#fafafa]">
    <div class="max-w-4xl">
      <FadeUp client:load>
        <span class="text-neutral-500 font-medium uppercase tracking-[0.2em] text-sm mb-6 block">Innovate Agency</span>
        <h1 class="text-6xl md:text-9xl font-extrabold tracking-tighter text-black leading-[0.9] mb-8">
          CRAFTING <br /> THE FUTURE <br /> OF DIGITAL.
        </h1>
        <p class="text-xl md:text-2xl text-neutral-600 max-w-xl leading-relaxed mb-10">
          We build high-performance experiences for brands that want to stand out and scale with elegance.
        </p>
        <div class="flex gap-4">
          <a href="/work" class="px-8 py-4 bg-black text-white rounded-full font-medium hover:bg-neutral-800 transition-all">View Our Work</a>
          <a href="/contact" class="px-8 py-4 border border-neutral-200 rounded-full font-medium hover:bg-white hover:border-black transition-all">Let's Talk</a>
        </div>
      </FadeUp>
    </div>
  </section>

  <!-- Summary Sections -->
  {homeSections.map((section, index) => (
    <section class="py-32 px-6 md:px-24 border-t border-neutral-100 bg-white overflow-hidden">
      <div class={`flex flex-col md:flex-row items-center gap-16 ${index % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
        <div class="w-full md:w-1/2">
          <FadeUp client:visible>
            <h2 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">{section.title}</h2>
            <p class="text-xl text-neutral-500 mb-8 max-w-lg leading-relaxed">{section.description}</p>
            <a href={section.link} class="group inline-flex items-center gap-2 text-lg font-bold border-b-2 border-black pb-1 hover:border-neutral-300 transition-all">
              {section.linkText}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </FadeUp>
        </div>
        <div class="w-full md:w-1/2">
           <FadeUp client:visible delay={0.2}>
              <div class="aspect-[4/3] overflow-hidden rounded-2xl bg-neutral-100">
                <img src={section.image} alt={section.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000" />
              </div>
           </FadeUp>
        </div>
      </div>
    </section>
  ))}

  <!-- Featured Case Studies -->
  <WorkSlider client:load items={caseStudies} title="Featured Work" />

  <!-- Testimonials -->
  <TestimonialSlider client:visible items={testimonials} title="What Clients Say" />

  <!-- FAQ Section -->
  <section class="py-32 px-6 md:px-24 bg-[#fafafa]">
    <div class="max-w-4xl mx-auto">
      <FadeUp client:visible>
        <h2 class="text-5xl md:text-7xl font-bold tracking-tight mb-16 text-center">FAQ</h2>
        <div class="space-y-6">
          {faqs.map((faq) => (
            <details class="group bg-white rounded-3xl border border-neutral-100 transition-all hover:border-neutral-200 overflow-hidden">
              <summary class="flex items-center justify-between p-8 cursor-pointer list-none">
                <h3 class="text-xl md:text-2xl font-bold tracking-tight">{faq.question}</h3>
                <div class="h-10 w-10 rounded-full bg-neutral-50 flex items-center justify-center transition-transform group-open:rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </summary>
              <div class="px-8 pb-8">
                <p class="text-neutral-500 text-lg leading-relaxed max-w-2xl">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </FadeUp>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-40 px-6 md:px-24 bg-black text-white text-center overflow-hidden relative">
    <div class="relative z-10">
      <FadeUp client:visible>
        <h2 class="text-6xl md:text-9xl font-extrabold tracking-tighter mb-12">READY TO <br /> INNOVATE?</h2>
        <a href="/contact" class="inline-flex items-center justify-center h-24 w-24 md:h-40 md:w-40 rounded-full bg-white text-black font-bold text-lg md:text-2xl hover:scale-110 transition-transform duration-500 uppercase tracking-tighter">
          Start
        </a>
      </FadeUp>
    </div>
    {/* Decorative background text */}
    <div class="absolute inset-0 flex items-center justify-center opacity-5 pointer-events-none">
       <span class="text-[30vw] font-black leading-none">INNOVATE</span>
    </div>
  </section>
</Layout>
