---
import Layout from '../layouts/Layout.astro';

const services = [
	{
		title: 'SEO Strategy',
		description: 'Dominating search rankings with advanced algorithmic alignment and high-authority link building ecosystems.',
		icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>'
	},
	{
		title: 'Performance Marketing',
		description: 'Hyper-targeted programmatic campaigns designed for maximum conversion velocity and minimal CAC.',
		icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path></svg>'
	},
	{
		title: 'Data Analytics',
		description: 'Transforming raw data pipelines into actionable, predictive insights using machine learning models.',
		icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>'
	}
];
---

<Layout title="Next-Gen Digital Marketing Agency">
	<!-- Hero Section -->
	<section class="relative max-w-7xl mx-auto px-4 md:px-6 pt-24 md:pt-32 pb-24 md:pb-32 flex flex-col items-center text-center">
		
		<!-- Badge -->
		<div class="animate-fade-in-up [animation-delay:0ms] opacity-0 inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[var(--border-color)] bg-[var(--bg-secondary)]/50 text-[var(--text-secondary)] text-xs md:text-sm font-medium mb-8 backdrop-blur-md">
			<span class="relative flex h-2 w-2">
			  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
			  <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
			</span>
			Vercel deployment live
		</div>

		<!-- Headline -->
		<h1 class="animate-fade-in-up [animation-delay:100ms] opacity-0 text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight mb-8 leading-[1.1] text-[var(--text-primary)]">
			Engineering <br class="hidden sm:block" />
			<span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 animate-shimmer bg-[length:200%_auto]">
				Digital Growth.
			</span>
		</h1>

		<!-- Subheadline -->
		<p class="animate-fade-in-up [animation-delay:200ms] opacity-0 text-lg md:text-xl lg:text-2xl text-[var(--text-secondary)] max-w-3xl mb-12 font-light leading-relaxed px-2">
			We architect precision-driven marketing strategies for enterprise startups. Outpace the competition with data, not guesswork.
		</p>

		<!-- CTAs -->
		<div class="animate-fade-in-up [animation-delay:300ms] opacity-0 flex flex-col sm:flex-row gap-4 w-full sm:w-auto px-4 sm:px-0">
			<a href="/contact" class="group relative px-8 py-4 bg-[var(--text-primary)] text-[var(--bg-primary)] font-semibold rounded-full overflow-hidden shadow-lg hover:shadow-cyan-500/25 transition-all hover:-translate-y-1 w-full sm:w-auto">
				<div class="absolute inset-0 w-full h-full bg-gradient-to-r from-cyan-400 to-blue-500 opacity-0 group-hover:opacity-10 transition-opacity"></div>
				<span class="relative flex items-center justify-center gap-2">
					Start a Project
					<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
				</span>
			</a>
			<a href="/services" class="px-8 py-4 border border-[var(--border-color)] bg-[var(--bg-primary)]/50 backdrop-blur-md text-[var(--text-primary)] font-medium rounded-full hover:bg-[var(--bg-secondary)] transition-colors flex items-center justify-center w-full sm:w-auto">
				Explore Services
			</a>
		</div>
	</section>

	<!-- Features Grid -->
	<section class="relative max-w-7xl mx-auto px-4 md:px-6 pb-24 md:pb-32">
		<!-- Background Glow for Grid -->
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] md:w-[600px] h-[300px] bg-purple-500/10 blur-[80px] md:blur-[100px] rounded-full pointer-events-none -z-10"></div>
		
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			{
				services.map((service, index) => (
					<div class={`animate-fade-in-up opacity-0 group relative p-8 rounded-3xl border border-[var(--border-color)] bg-[var(--bg-primary)]/70 backdrop-blur-xl hover:border-cyan-500/30 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:hover:shadow-[0_8px_30px_rgba(6,182,212,0.1)] overflow-hidden`} style={`animation-delay: ${400 + (index * 100)}ms`}>
						<!-- Hover Gradient Background -->
						<div class="absolute inset-0 bg-gradient-to-br from-cyan-500/5 to-purple-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
						
						<div class="relative z-10">
							<div class="w-12 h-12 mb-6 rounded-2xl bg-cyan-500/10 text-cyan-600 dark:text-cyan-400 flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
								<Fragment set:html={service.icon} />
							</div>
							<h3 class="text-2xl font-bold mb-4 tracking-tight">{service.title}</h3>
							<p class="text-[var(--text-secondary)] leading-relaxed">
								{service.description}
							</p>
						</div>
					</div>
				))
			}
		</div>
	</section>
	
	<!-- Social Proof / Brands Section -->
	<section>
		<div class="max-w-7xl mx-auto px-6 flex flex-col items-center">
			<p class="text-sm font-semibold text-[var(--text-secondary)] tracking-widest uppercase mb-8 text-center">Trusted by innovative teams</p>
			<div class="flex flex-wrap justify-center gap-8 md:gap-12 opacity-40 grayscale hover:grayscale-0 transition-all duration-500 text-[var(--text-primary)]">
				<!-- Dummy Logos (SVG) -->
				<svg class="h-6 md:h-8" viewBox="0 0 100 30" fill="currentColor"><path d="M10 15a5 5 0 100-10 5 5 0 000 10zm0 5a10 10 0 110-20 10 10 0 010 20z"/><text x="25" y="20" font-weight="bold" font-size="16" font-family="sans-serif">AcmeCorp</text></svg>
				<svg class="h-6 md:h-8" viewBox="0 0 100 30" fill="currentColor"><rect x="0" y="5" width="20" height="20" rx="4"/><text x="28" y="21" font-weight="bold" font-size="16" font-family="sans-serif">Nexus</text></svg>
				<svg class="h-6 md:h-8" viewBox="0 0 100 30" fill="currentColor"><polygon points="10,5 20,25 0,25"/><text x="25" y="20" font-weight="bold" font-size="16" font-family="sans-serif">Vertex</text></svg>
				<svg class="h-6 md:h-8" viewBox="0 0 100 30" fill="currentColor"><circle cx="10" cy="15" r="8"/><circle cx="20" cy="15" r="8" fill-opacity="0.5"/><text x="35" y="20" font-weight="bold" font-size="16" font-family="sans-serif">Quantum</text></svg>
			</div>
		</div>
	</section>
</Layout>
