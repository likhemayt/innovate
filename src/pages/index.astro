---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Digital Marketing Agency">
	<div class="max-w-7xl mx-auto px-6 py-24 flex flex-col items-center text-center">
		<h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">
			Elevate Your Digital <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-cyan-400">Presence</span>.
		</h1>
		<p class="text-xl text-[var(--text-secondary)] max-w-2xl mb-12">
			We are Innovate, a corporate digital marketing agency specializing in data-driven strategies, 
			SEO optimization, and enterprise-level growth solutions.
		</p>
		<div class="flex gap-4">
			<a href="/contact" class="px-8 py-3 bg-[var(--text-primary)] text-[var(--bg-primary)] font-medium rounded-lg hover:opacity-90 transition-opacity">
				Start a Project
			</a>
			<a href="/services" class="px-8 py-3 border border-[var(--border-color)] text-[var(--text-primary)] font-medium rounded-lg hover:bg-[var(--border-color)] transition-colors">
				Our Services
			</a>
		</div>
	</div>

	<div class="max-w-7xl mx-auto px-6 py-24">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			{
				['SEO Strategy', 'Performance Marketing', 'Data Analytics'].map((service) => (
					<div class="p-8 border border-[var(--border-color)] rounded-2xl bg-[var(--bg-secondary)] hover:-translate-y-1 transition-transform duration-300">
						<h3 class="text-xl font-bold mb-3">{service}</h3>
						<p class="text-[var(--text-secondary)]">
							Comprehensive strategies tailored for your business needs to drive measurable growth and ROI.
						</p>
					</div>
				))
			}
		</div>
	</div>
</Layout>
