---
import Layout from '../layouts/Layout.astro';
import FadeUp from '../components/animations/FadeUp.astro';

const projects = [
  {
    title: "Project Alpha",
    category: "Branding",
    year: "2024",
    image: "https://images.unsplash.com/photo-1614850523296-d8c1af93d400?q=80&w=2070&auto=format&fit=crop",
    metric: "42% Conversion Lift"
  },
  {
    title: "Zenith Banking",
    category: "Product Design",
    year: "2024",
    image: "https://images.unsplash.com/photo-1563986768609-322da13575f3?q=80&w=2070&auto=format&fit=crop",
    metric: "2M+ Active Users"
  },
  {
    title: "Lumina Studio",
    category: "Web Development",
    year: "2023",
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2015&auto=format&fit=crop",
    metric: "Sub-1s Load Time"
  },
  {
    title: "Aura Fashions",
    category: "E-Commerce",
    year: "2023",
    image: "https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=2070&auto=format&fit=crop",
    metric: "150% Sales YoY"
  },
  {
    title: "Nexus OS",
    category: "UI/UX Design",
    year: "2023",
    image: "https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=2072&auto=format&fit=crop",
    metric: "1M+ Downloads"
  },
  {
    title: "Void Records",
    category: "Visual Identity",
    year: "2022",
    image: "https://images.unsplash.com/photo-1514525253361-bee8718a34a1?q=80&w=2064&auto=format&fit=crop",
    metric: "Global Launch"
  }
];
---

<Layout 
  title="B2B Digital Portfolio & Case Studies"
  description="Six case studies across branding, product design, web development, and e-commerce - work crafted for high-growth B2B brands since 2018."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "CollectionPage",
          "@id": "https://innovate-proto.vercel.app/work#webpage",
          "url": "https://innovate-proto.vercel.app/work",
          "name": "Selected Work - B2B Digital Portfolio",
          "description": "Six case studies across branding, product design, web development, and e-commerce.",
          "breadcrumb": { "@id": "https://innovate-proto.vercel.app/work#breadcrumb" },
          "hasPart": [
            { "@type": "CreativeWork", "name": "Project Alpha", "genre": "Branding", "datePublished": "2024" },
            { "@type": "CreativeWork", "name": "Zenith Banking", "genre": "Product Design", "datePublished": "2024" },
            { "@type": "CreativeWork", "name": "Lumina Studio", "genre": "Web Development", "datePublished": "2023" },
            { "@type": "CreativeWork", "name": "Aura Fashions", "genre": "E-Commerce", "datePublished": "2023" },
            { "@type": "CreativeWork", "name": "Nexus OS", "genre": "UI/UX Design", "datePublished": "2023" },
            { "@type": "CreativeWork", "name": "Void Records", "genre": "Visual Identity", "datePublished": "2022" }
          ]
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://innovate-proto.vercel.app/work#breadcrumb",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://innovate-proto.vercel.app/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Work",
              "item": "https://innovate-proto.vercel.app/work"
            }
          ]
        }
      ]
    }
    </script>
  </Fragment>

  <section class="py-20 md:py-32 px-6 md:px-24">
    <FadeUp nojs={true}>
      <h1 class="text-[clamp(3.5rem,10vw,12rem)] font-black tracking-[-0.05em] mb-12 uppercase leading-[0.8]">SELECTED <br /> WORK.</h1>
      <p class="text-xl md:text-3xl text-neutral-500 max-w-3xl leading-relaxed">
        A selection of digital experiences we've crafted for forward-thinking brands.
      </p>
    </FadeUp>
  </section>

  <section class="py-20 md:py-32 px-6 md:px-24 bg-white border-t border-neutral-100">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-24 md:gap-y-48 md:pt-24">
      {projects.map((project, index) => (
        <FadeUp class={`group cursor-pointer ${index % 2 === 1 ? 'md:translate-y-48' : ''}`} data-cursor="view">
          <div class="aspect-[3/4] md:aspect-[4/5] overflow-hidden rounded-[2.5rem] bg-neutral-100 mb-8 relative" data-reveal="image">
             <img src={project.image} alt={project.title} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" loading="lazy" width="800" height="1000" />
          </div>
          <div class="flex items-end justify-between px-2">
            <div>
               <span class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-2 block">{project.category} / {project.year}</span>
               <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">{project.title}</h2>
               <span class="inline-block px-4 py-2 bg-neutral-100 rounded-full text-sm font-bold">{project.metric}</span>
            </div>
            <div class="h-14 w-14 rounded-full border border-neutral-200 flex items-center justify-center group-hover:bg-black group-hover:text-white group-hover:border-black transition-all duration-500 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="-rotate-45 group-hover:rotate-0 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </div>
        </FadeUp>
      ))}
    </div>
  </section>
</Layout>
