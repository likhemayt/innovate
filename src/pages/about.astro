---
import Layout from '../layouts/Layout.astro';
import FadeUp from '../components/animations/FadeUp';

const values = [
  { title: "Design First", description: "We believe that aesthetics and function are inseparable. Design is the first impression and the lasting impact." },
  { title: "Human Centric", description: "We build for people. Every pixel and line of code should serve a human purpose." },
  { title: "Technical Rigor", description: "Performance is a design feature. We never compromise on the speed or stability of our products." },
  { title: "Open Collaboration", description: "We work as an extension of your team. Transparency and communication are our core values." }
];
---

<Layout title="About Us">
  <section class="py-32 px-6 md:px-24">
    <FadeUp client:load>
      <h1 class="text-6xl md:text-9xl font-extrabold tracking-tighter mb-12">WHO <br /> WE ARE.</h1>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <p class="text-xl md:text-2xl text-neutral-600 leading-relaxed">
          Innovate was founded on the principle that the best digital products are born at the intersection of creative intuition and technical precision.
        </p>
        <p class="text-lg text-neutral-400 leading-relaxed pt-2">
          We are a compact, specialized team of multidisciplinary experts. We don't have account managers or middlemen—you work directly with the makers. This leads to faster iterations, deeper insights, and ultimately, better results.
        </p>
      </div>
    </FadeUp>
  </section>

  <section class="py-32 px-6 md:px-24 bg-white border-y border-neutral-100">
    <div class="mb-24">
      <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-8">OUR VALUES.</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {values.map((value) => (
        <FadeUp client:visible className="p-8 bg-[#fafafa] rounded-2xl">
          <h3 class="text-2xl font-bold mb-4">{value.title}</h3>
          <p class="text-neutral-500 leading-relaxed">{value.description}</p>
        </FadeUp>
      ))}
    </div>
  </section>

  <section class="py-32 px-6 md:px-24">
    <div class="aspect-[21/9] w-full overflow-hidden rounded-3xl bg-neutral-100 mb-24">
       <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2069&auto=format&fit=crop" alt="Our Studio" class="w-full h-full object-cover" />
    </div>
    <div class="text-center">
       <FadeUp client:visible>
         <h2 class="text-4xl md:text-6xl font-bold mb-8">JOIN OUR JOURNEY.</h2>
         <a href="/contact" class="text-2xl font-bold border-b-2 border-black pb-2 hover:border-neutral-300 transition-all">Work with us</a>
       </FadeUp>
    </div>
  </section>
</Layout>
