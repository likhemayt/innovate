---
import Layout from '../layouts/Layout.astro';
import FadeUp from '../components/animations/FadeUp.astro';

const values = [
  { title: "Design First", description: "We believe that aesthetics and function are inseparable. Design is the first impression and the lasting impact." },
  { title: "Human Centric", description: "We build for people. Every pixel and line of code should serve a human purpose." },
  { title: "Technical Rigor", description: "Performance is a design feature. We never compromise on the speed or stability of our products." },
  { title: "Open Collaboration", description: "We work as an extension of your team. Transparency and communication are our core values." }
];
---

<Layout 
  title="About Innovate - B2B Digital Agency Since 2018"
  description="Founded in 2018, Innovate is a digital creative agency built at the intersection of design excellence and technical precision for B2B brands."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "AboutPage",
          "@id": "https://innovate-proto.vercel.app/about#webpage",
          "url": "https://innovate-proto.vercel.app/about",
          "name": "About Innovate - B2B Digital Agency Since 2018",
          "breadcrumb": { "@id": "https://innovate-proto.vercel.app/about#breadcrumb" },
          "mainEntity": { "@id": "https://innovate-proto.vercel.app/#organization" }
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://innovate-proto.vercel.app/about#breadcrumb",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://innovate-proto.vercel.app/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "About",
              "item": "https://innovate-proto.vercel.app/about"
            }
          ]
        }
      ]
    }
    </script>
  </Fragment>

  <section class="py-20 md:py-32 px-6 md:px-24">
    <FadeUp nojs={true}>
      <h1 class="text-[clamp(3.5rem,10vw,12rem)] font-black tracking-[-0.05em] mb-12 uppercase leading-[0.8]">CRAFTING THE <br /> FUTURE SINCE 2018.</h1>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <p class="text-xl md:text-2xl text-neutral-600 leading-relaxed">
          Innovate was founded on the principle that the best digital products are born at the intersection of creative intuition and technical precision.
        </p>
        <p class="text-lg text-neutral-400 leading-relaxed pt-2">
          We are a compact, specialized team of multidisciplinary experts. We don't have account managers or middlemen—you work directly with the makers. This leads to faster iterations, deeper insights, and ultimately, better results.
        </p>
      </div>
    </FadeUp>
  </section>

  <section class="py-20 md:py-32 px-6 md:px-24 bg-white border-y border-neutral-100">
    <div class="mb-24">
      <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-8">OUR VALUES.</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {values.map((value) => (
        <FadeUp class="p-8 bg-[#fafafa] rounded-2xl">
          <h3 class="text-2xl font-bold mb-4">{value.title}</h3>
          <p class="text-neutral-500 leading-relaxed">{value.description}</p>
        </FadeUp>
      ))}
    </div>
  </section>

  <section class="py-20 md:py-32 px-6 md:px-24">
    <div class="aspect-[21/9] w-full overflow-hidden rounded-[2.5rem] bg-neutral-100 mb-24 relative" data-reveal="image">
       <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2069&auto=format&fit=crop" alt="Our Studio" class="w-full h-full object-cover" loading="lazy" width="2069" height="886" />
    </div>
    
    <!-- Team Section -->
    <div class="mb-16">
      <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-8">OUR TEAM.</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-24">
      <FadeUp>
        <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=800&auto=format&fit=crop" alt="Marcus Chen" class="w-full aspect-[4/5] object-cover rounded-[2rem] mb-6" loading="lazy" width="800" height="1000" />
        <h3 class="text-2xl font-bold">Marcus Chen</h3>
        <p class="text-neutral-500 mb-2">Founder & Technical Director</p>
        <a href="https://linkedin.com/company/innovate" class="text-sm font-bold border-b border-black pb-1">LinkedIn</a>
      </FadeUp>
      <FadeUp delay={0.1}>
        <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=800&auto=format&fit=crop" alt="Sarah Jenkins" class="w-full aspect-[4/5] object-cover rounded-[2rem] mb-6" loading="lazy" width="800" height="1000" />
        <h3 class="text-2xl font-bold">Sarah Jenkins</h3>
        <p class="text-neutral-500 mb-2">Head of Design</p>
        <a href="https://linkedin.com/company/innovate" class="text-sm font-bold border-b border-black pb-1">LinkedIn</a>
      </FadeUp>
      <FadeUp delay={0.2}>
        <img src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=800&auto=format&fit=crop" alt="David Miller" class="w-full aspect-[4/5] object-cover rounded-[2rem] mb-6" loading="lazy" width="800" height="1000" />
        <h3 class="text-2xl font-bold">David Miller</h3>
        <p class="text-neutral-500 mb-2">Lead Developer</p>
        <a href="https://linkedin.com/company/innovate" class="text-sm font-bold border-b border-black pb-1">LinkedIn</a>
      </FadeUp>
    </div>

    <div class="text-center">
       <FadeUp>
         <h2 class="text-4xl md:text-6xl font-bold mb-8">JOIN OUR JOURNEY.</h2>
         <a href="/contact" class="text-2xl font-bold border-b-2 border-black pb-2 hover:border-neutral-300 transition-all">Work with us</a>
       </FadeUp>
    </div>
  </section>
</Layout>
