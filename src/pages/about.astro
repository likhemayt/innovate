---
import Layout from '../layouts/Layout.astro';

const stats = [
	{ value: '360+', label: 'Clients Worldwide' },
	{ value: '50+',  label: 'Team Members' },
	{ value: '480+', label: 'Projects Completed' },
	{ value: '$150M', label: 'Revenue Generated' },
];

const values = [
	{
		title: 'Execution',
		desc: 'We deliver on every commitment. Strategy without execution is just theory — we ship, measure, and iterate relentlessly.',
		icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>',
	},
	{
		title: 'Accountability',
		desc: 'Every campaign we run is tied to real KPIs. We own outcomes, not just activity, and we stand behind every number we report.',
		icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
	},
	{
		title: 'Growth',
		desc: 'Growth is not a metric — it\'s a mindset. We are obsessed with compounding gains that build lasting competitive moats for our clients.',
		icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>',
	},
	{
		title: 'Creativity',
		desc: 'Data informs, but creativity wins. We pair rigorous analytics with bold creative thinking to break through the noise.',
		icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m1.636-6.364l.707.707M12 21v-1M7 17l-1 1M17 17l1 1M12 8a4 4 0 100 8 4 4 0 000-8z"></path></svg>',
	},
	{
		title: 'Client First',
		desc: 'Our clients\' goals are our goals. We treat every partnership as a long-term relationship, not a transactional engagement.',
		icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>',
	},
	{
		title: 'Leadership',
		desc: 'We set the pace in our industry. Through thought leadership, pioneering tools, and proactive strategy, we stay two steps ahead.',
		icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>',
	},
];

const team = [
	{
		name: 'James Harlow',
		role: 'CEO & Founder',
		bio: 'Former VP of Growth at two unicorn startups. James founded Innovate in 2016 with a belief that marketing should be measurable and honest.',
		gradient: 'from-cyan-400 to-blue-600',
		socials: { twitter: '#', linkedin: '#' },
	},
	{
		name: 'Mia Chen',
		role: 'CTO & Co-Founder',
		bio: 'Data scientist turned marketer. Mia architects our analytics infrastructure and ensures every campaign decision is evidence-driven.',
		gradient: 'from-purple-400 to-pink-500',
		socials: { twitter: '#', linkedin: '#' },
	},
	{
		name: 'Daniel Park',
		role: 'Head of Performance',
		bio: 'Managed $80M+ in ad spend across global markets. Daniel leads our paid acquisition team with a focus on efficiency and scale.',
		gradient: 'from-blue-400 to-cyan-500',
		socials: { twitter: '#', linkedin: '#' },
	},
	{
		name: 'Sofia Laurent',
		role: 'Creative Director',
		bio: 'Award-winning creative strategist who believes great design and great data are not opposites — they\'re multipliers.',
		gradient: 'from-orange-400 to-rose-500',
		socials: { twitter: '#', linkedin: '#' },
	},
	{
		name: 'Ethan Brooks',
		role: 'Head of SEO',
		bio: 'Built and sold two niche content businesses before joining Innovate. Ethan lives and breathes organic search and content systems.',
		gradient: 'from-emerald-400 to-teal-600',
		socials: { twitter: '#', linkedin: '#' },
	},
	{
		name: 'Anika Sharma',
		role: 'Head of Client Success',
		bio: '10+ years turning client relationships into long-term partnerships. Anika ensures every client feels heard, valued, and growing.',
		gradient: 'from-violet-400 to-purple-600',
		socials: { twitter: '#', linkedin: '#' },
	},
];

const offices = [
	{
		city: 'Singapore',
		address: '1 Marina Blvd, #28-00, Singapore 018989',
		email: 'sg@innovate.digital',
		desc: 'Our APAC headquarters and founding office, home to our strategy and analytics teams.',
	},
	{
		city: 'New York',
		address: '335 Madison Ave, 9th Floor, New York, NY 10017',
		email: 'nyc@innovate.digital',
		desc: 'Our North America hub, driving performance campaigns across the US and Canada.',
	},
	{
		city: 'London',
		address: '20 Fenchurch St, Level 12, London EC3M 3BY',
		email: 'ldn@innovate.digital',
		desc: 'Our European centre of excellence, leading SEO and content strategy for EMEA clients.',
	},
];

const press = [
	{ quote: 'Simply the best growth agency we\'ve ever worked with.', source: 'Forbes' },
	{ quote: 'Innovate is redefining what performance marketing looks like at scale.', source: 'TechCrunch' },
	{ quote: 'The #1 digital agency for data-first brands in Southeast Asia.', source: 'Marketing Week' },
	{ quote: 'A rare agency that pairs creative brilliance with hard analytics.', source: 'Adweek' },
];
---

<Layout title="About Us">

	<!-- ─── Hero ─────────────────────────────────────────────────────────── -->
	<section class="relative max-w-7xl mx-auto px-4 md:px-6 pt-10 md:pt-16 pb-16 md:pb-20">

		<!-- Eyebrow + Headline -->
		<div class="max-w-4xl mb-14 md:mb-20">
			<p class="animate-fade-in-up [animation-delay:0ms] opacity-0 text-[0.65rem] font-semibold text-cyan-500 tracking-[0.25em] uppercase mb-5">About Innovate</p>
			<h1 class="animate-fade-in-up [animation-delay:80ms] opacity-0 text-[clamp(2.8rem,7vw,5.5rem)] font-extrabold tracking-tight leading-[1.06] text-[var(--text-primary)]">
				A great company has<br class="hidden sm:block"/>
				a <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 animate-shimmer bg-[length:200%_auto]">great team</span> behind it.
			</h1>
			<p class="animate-fade-in-up [animation-delay:180ms] opacity-0 text-lg md:text-xl text-[var(--text-secondary)] max-w-2xl mt-7 font-light leading-relaxed">
				Founded in 2016, Innovate is a precision-driven digital marketing agency trusted by 360+ brands worldwide. We combine deep data science with bold creative thinking to build growth engines that last.
			</p>
			<div class="animate-fade-in-up [animation-delay:280ms] opacity-0 mt-8">
				<a href="/contact" class="group inline-flex items-center gap-2 px-7 py-3.5 min-h-[44px] bg-[var(--text-primary)] text-[var(--bg-primary)] font-semibold rounded-full shadow-lg hover:shadow-cyan-500/20 transition-all hover:-translate-y-0.5 text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg-primary)]">
					Join Our Team
					<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
				</a>
			</div>
		</div>

		<!-- Stats row -->
		<div class="animate-fade-in-up [animation-delay:380ms] opacity-0 grid grid-cols-2 md:grid-cols-4 border border-[var(--border-color)] rounded-3xl overflow-hidden divide-y md:divide-y-0 md:divide-x divide-[var(--border-color)]">
			{stats.map(stat => (
				<div class="flex flex-col items-center justify-center text-center py-10 px-6 bg-[var(--bg-secondary)]/40">
					<span class="text-4xl md:text-5xl font-extrabold text-[var(--text-primary)] tracking-tight leading-none">{stat.value}</span>
					<span class="text-xs text-[var(--text-secondary)] mt-3 tracking-widest uppercase">{stat.label}</span>
				</div>
			))}
		</div>
	</section>

	<!-- ─── Section 01: Our Story ─────────────────────────────────────────── -->
	<section class="border-t border-[var(--border-color)] py-20 md:py-28">
		<div class="max-w-7xl mx-auto px-4 md:px-6">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-20 items-center">

				<!-- Text -->
				<div>
					<p class="text-[0.65rem] font-semibold text-cyan-500 tracking-[0.25em] uppercase mb-5 flex items-center gap-3">
						<span class="text-[var(--text-secondary)] font-mono">01</span>
						Our Story
					</p>
					<h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[var(--text-primary)] leading-tight mb-8">
						We thrive to give our clients a global impact.
					</h2>
					<div class="space-y-5 text-[var(--text-secondary)] leading-relaxed">
						<p>Innovate started with a simple conviction: that marketing decisions should be driven by data, not gut feelings. Our founders — a data scientist and a growth marketer — spent years watching great products fail because of poor marketing strategy. They built Innovate to fix that.</p>
						<p>Today, we partner with ambitious startups and enterprise teams across APAC, North America, and Europe. Our approach is the same at every scale: understand the business deeply, build the strategy meticulously, and execute with relentless precision.</p>
						<p>We don't just run campaigns. We build growth systems that compound over time.</p>
					</div>
					<a href="/services" class="mt-10 inline-flex items-center gap-2 text-sm font-medium text-[var(--text-primary)] border border-[var(--border-color)] px-5 py-2.5 min-h-[44px] rounded-full hover:bg-[var(--bg-secondary)] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg-primary)]">
						Explore our services
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
					</a>
				</div>

				<!-- Visual: decorative grid of stat/quote blocks -->
				<div class="grid grid-cols-2 gap-4">
					<div class="col-span-2 p-8 rounded-3xl border border-[var(--border-color)] bg-gradient-to-br from-cyan-500/5 to-blue-600/5 flex flex-col gap-3">
						<svg class="w-7 h-7 text-cyan-500/50" viewBox="0 0 32 32" fill="currentColor"><path d="M10 8C6.686 8 4 10.686 4 14v10h10V14H7c0-1.654 1.346-3 3-3V8zm14 0c-3.314 0-6 2.686-6 6v10h10V14h-7c0-1.654 1.346-3 3-3V8z"/></svg>
						<p class="text-[var(--text-primary)] text-lg font-medium leading-relaxed">"We don't just run campaigns — we build growth engines that compound over years, not quarters."</p>
						<p class="text-sm text-[var(--text-secondary)]">James Harlow, CEO & Founder</p>
					</div>
					<div class="p-6 rounded-3xl border border-[var(--border-color)] bg-[var(--bg-secondary)]/40 flex flex-col gap-2">
						<span class="text-4xl font-extrabold text-[var(--text-primary)] tracking-tight">2016</span>
						<span class="text-xs text-[var(--text-secondary)] tracking-wide uppercase">Founded</span>
					</div>
					<div class="p-6 rounded-3xl border border-cyan-500/20 bg-cyan-500/5 flex flex-col gap-2">
						<span class="text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500 tracking-tight">3</span>
						<span class="text-xs text-[var(--text-secondary)] tracking-wide uppercase">Global Offices</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── Section 02: Values ────────────────────────────────────────────── -->
	<section class="border-t border-[var(--border-color)] bg-[var(--bg-secondary)]/30 py-20 md:py-28">
		<div class="max-w-7xl mx-auto px-4 md:px-6">
			<div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14">
				<div>
					<p class="text-[0.65rem] font-semibold text-cyan-500 tracking-[0.25em] uppercase mb-5 flex items-center gap-3">
						<span class="text-[var(--text-secondary)] font-mono">02</span>
						Our Values
					</p>
					<h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[var(--text-primary)] leading-tight">
						High-impact principles<br/>we live by.
					</h2>
				</div>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
				{values.map(v => (
					<div class="group p-8 rounded-3xl border border-[var(--border-color)] bg-[var(--bg-primary)]/60 hover:border-cyan-500/25 hover:bg-[var(--bg-primary)] transition-all duration-300 flex flex-col gap-5">
						<div class="w-11 h-11 rounded-2xl bg-cyan-500/10 text-cyan-500 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
							<Fragment set:html={v.icon} />
						</div>
						<h3 class="text-xl font-bold text-[var(--text-primary)]">{v.title}</h3>
						<p class="text-[var(--text-secondary)] text-sm leading-relaxed">{v.desc}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── Section 03: Team ──────────────────────────────────────────────── -->
	<section class="border-t border-[var(--border-color)] py-20 md:py-28">
		<div class="max-w-7xl mx-auto px-4 md:px-6">
			<div class="mb-14">
				<p class="text-[0.65rem] font-semibold text-cyan-500 tracking-[0.25em] uppercase mb-5 flex items-center gap-3">
					<span class="text-[var(--text-secondary)] font-mono">03</span>
					Our Team
				</p>
				<h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[var(--text-primary)] leading-tight">
					Meet the people<br/>behind Innovate.
				</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
				{team.map(member => (
					<div class="group flex flex-col gap-5 p-7 rounded-3xl border border-[var(--border-color)] bg-[var(--bg-primary)]/50 hover:border-cyan-500/25 hover:bg-[var(--bg-secondary)] transition-all duration-300">
						<!-- Avatar -->
						<div class={`w-16 h-16 rounded-full bg-gradient-to-br ${member.gradient} flex items-center justify-center text-white text-2xl font-bold shrink-0`}>
							{member.name.split(' ').map((n: string) => n[0]).join('')}
						</div>
						<div>
							<h3 class="text-lg font-bold text-[var(--text-primary)]">{member.name}</h3>
							<p class="text-xs text-cyan-500 font-medium tracking-wide mt-0.5">{member.role}</p>
						</div>
						<p class="text-[var(--text-secondary)] text-sm leading-relaxed flex-grow">{member.bio}</p>
						<!-- Socials -->
						<div class="flex items-center gap-3 pt-4 border-t border-[var(--border-color)]">
							<a href={member.socials.twitter} aria-label="Twitter profile" class="w-11 h-11 rounded-full border border-[var(--border-color)] flex items-center justify-center text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--text-secondary)] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500">
								<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.745l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
							</a>
							<a href={member.socials.linkedin} aria-label="LinkedIn profile" class="w-11 h-11 rounded-full border border-[var(--border-color)] flex items-center justify-center text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--text-secondary)] transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500">
								<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
							</a>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── Section 04: Join the Team ─────────────────────────────────────── -->
	<section class="border-t border-[var(--border-color)] bg-[var(--bg-secondary)]/30 py-20 md:py-28">
		<div class="max-w-7xl mx-auto px-4 md:px-6">
			<div class="relative rounded-3xl overflow-hidden border border-[var(--border-color)] p-12 md:p-20 flex flex-col md:flex-row items-center justify-between gap-10 bg-[var(--bg-primary)]/40">
				<div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 10% 90%, rgba(6,182,212,0.10) 0%, transparent 55%), radial-gradient(ellipse at 90% 10%, rgba(139,92,246,0.08) 0%, transparent 55%);"></div>
				<div class="relative z-10 max-w-xl">
					<p class="text-[0.65rem] font-semibold text-cyan-500 tracking-[0.25em] uppercase mb-5 flex items-center gap-3">
						<span class="text-[var(--text-secondary)] font-mono">04</span>
						Careers
					</p>
					<h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[var(--text-primary)] leading-tight">
						Want to be part of<br/>our amazing team?
					</h2>
					<p class="text-[var(--text-secondary)] mt-5 leading-relaxed">We're always looking for exceptional talent who are passionate about growth, data, and creativity. If that sounds like you, let's talk.</p>
				</div>
				<div class="relative z-10 flex flex-col sm:flex-row gap-4 shrink-0">
					<a href="/contact" class="group px-8 py-4 min-h-[44px] bg-[var(--text-primary)] text-[var(--bg-primary)] font-semibold rounded-full shadow-lg hover:shadow-cyan-500/20 transition-all hover:-translate-y-0.5 flex items-center justify-center gap-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg-primary)]">
						Get in Touch
						<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
					</a>
					<a href="/contact" class="px-8 py-4 min-h-[44px] border border-[var(--border-color)] text-[var(--text-primary)] font-medium rounded-full hover:bg-[var(--bg-secondary)] transition-colors flex items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg-primary)]">
						View Open Roles
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ─── Section 05: Offices ───────────────────────────────────────────── -->
	<section class="border-t border-[var(--border-color)] py-20 md:py-28">
		<div class="max-w-7xl mx-auto px-4 md:px-6">
			<div class="mb-14">
				<p class="text-[0.65rem] font-semibold text-cyan-500 tracking-[0.25em] uppercase mb-5 flex items-center gap-3">
					<span class="text-[var(--text-secondary)] font-mono">05</span>
					Global Offices
				</p>
				<h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[var(--text-primary)] leading-tight">
					Visit our offices<br/>around the globe.
				</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				{offices.map(office => (
					<a href={`mailto:${office.email}`} class="group flex flex-col gap-5 p-8 rounded-3xl border border-[var(--border-color)] bg-[var(--bg-primary)]/50 hover:border-cyan-500/25 hover:bg-[var(--bg-secondary)] transition-all duration-300 cursor-pointer">
						<!-- Map pin icon -->
						<div class="w-11 h-11 rounded-2xl bg-cyan-500/10 text-cyan-500 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
						</div>
						<div>
							<h3 class="text-xl font-bold text-[var(--text-primary)]">{office.city}</h3>
							<p class="text-xs text-[var(--text-secondary)] mt-1">{office.address}</p>
						</div>
						<p class="text-sm text-[var(--text-secondary)] leading-relaxed flex-grow">{office.desc}</p>
						<div class="flex items-center gap-2 text-cyan-500 text-sm font-medium pt-4 border-t border-[var(--border-color)] group-hover:gap-3 transition-all duration-300">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
							{office.email}
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- ─── Section 06: Press ─────────────────────────────────────────────── -->
	<section class="border-t border-[var(--border-color)] bg-[var(--bg-secondary)]/30 py-20 md:py-28">
		<div class="max-w-7xl mx-auto px-4 md:px-6">
			<div class="mb-14">
				<p class="text-[0.65rem] font-semibold text-cyan-500 tracking-[0.25em] uppercase mb-5 flex items-center gap-3">
					<span class="text-[var(--text-secondary)] font-mono">06</span>
					Press
				</p>
				<h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[var(--text-primary)] leading-tight">
					What the press<br/>says about us.
				</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
				{press.map(item => (
					<div class="group flex flex-col justify-between gap-6 p-8 rounded-3xl border border-[var(--border-color)] bg-[var(--bg-primary)]/50 hover:border-cyan-500/25 hover:bg-[var(--bg-primary)] transition-all duration-300">
						<svg class="w-7 h-7 text-cyan-500/40" viewBox="0 0 32 32" fill="currentColor"><path d="M10 8C6.686 8 4 10.686 4 14v10h10V14H7c0-1.654 1.346-3 3-3V8zm14 0c-3.314 0-6 2.686-6 6v10h10V14h-7c0-1.654 1.346-3 3-3V8z"/></svg>
						<p class="text-xl md:text-2xl font-semibold text-[var(--text-primary)] leading-snug">"{item.quote}"</p>
						<div class="pt-4 border-t border-[var(--border-color)]">
							<span class="text-sm font-bold text-[var(--text-secondary)] tracking-widest uppercase">{item.source}</span>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ─── Final CTA ─────────────────────────────────────────────────────── -->
	<section class="max-w-7xl mx-auto px-4 md:px-6 py-24 md:py-32">
		<div class="relative rounded-3xl overflow-hidden border border-[var(--border-color)] p-12 md:p-20 flex flex-col md:flex-row items-center justify-between gap-10 bg-[var(--bg-secondary)]/40">
			<div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 20% 80%, rgba(6,182,212,0.10) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(139,92,246,0.08) 0%, transparent 60%);"></div>
			<div class="relative z-10 max-w-xl">
				<p class="text-[0.65rem] font-semibold text-cyan-500 tracking-[0.25em] uppercase mb-4">Ready to Grow?</p>
				<h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-[var(--text-primary)] leading-[1.1]">
					Need help on a project?<br/>
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Get in touch today.</span>
				</h2>
			</div>
			<div class="relative z-10 flex flex-col sm:flex-row gap-4 shrink-0">
				<a href="/contact" class="group px-8 py-4 min-h-[44px] bg-[var(--text-primary)] text-[var(--bg-primary)] font-semibold rounded-full shadow-lg hover:shadow-cyan-500/20 transition-all hover:-translate-y-0.5 flex items-center justify-center gap-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg-primary)]">
					Get in Touch
					<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
				</a>
				<a href="/services" class="px-8 py-4 min-h-[44px] border border-[var(--border-color)] text-[var(--text-primary)] font-medium rounded-full hover:bg-[var(--bg-secondary)] transition-colors flex items-center justify-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--bg-primary)]">
					Explore Services
				</a>
			</div>
		</div>
	</section>

</Layout>
