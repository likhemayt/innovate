---
import Layout from '../layouts/Layout.astro';
import FadeUp from '../components/animations/FadeUp';
---

<Layout title="Contact Us">
  <section class="py-32 px-6 md:px-24 min-h-[90vh] flex flex-col justify-center">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
      <div>
        <FadeUp client:load>
          <h1 class="text-6xl md:text-9xl font-extrabold tracking-tighter mb-12">HELLO.</h1>
          <p class="text-xl md:text-2xl text-neutral-500 max-w-md leading-relaxed mb-16">
            Have a project in mind? Let's build something extraordinary together.
          </p>
          
          <div class="space-y-12">
            <div>
              <h4 class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-4">Email Us</h4>
              <a href="mailto:hello@innovate.agency" class="text-2xl md:text-4xl font-bold hover:text-neutral-500 transition-colors underline underline-offset-8 decoration-1">hello@innovate.agency</a>
            </div>
            <div>
              <h4 class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-4">Visit Us</h4>
              <p class="text-2xl md:text-4xl font-bold">123 Design Street,<br />Studio 42, London UK</p>
            </div>
          </div>
        </FadeUp>
      </div>
      
      <div class="bg-white p-12 rounded-3xl border border-neutral-100 shadow-xl shadow-neutral-100/50">
        <FadeUp client:load delay={0.2}>
          <form class="space-y-8">
            <div class="space-y-2">
              <label class="text-sm font-bold uppercase tracking-widest text-neutral-400">Name</label>
              <input type="text" placeholder="John Doe" class="w-full bg-neutral-50 border-b-2 border-neutral-100 p-4 focus:border-black focus:outline-none transition-colors" />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold uppercase tracking-widest text-neutral-400">Email</label>
              <input type="email" placeholder="john@example.com" class="w-full bg-neutral-50 border-b-2 border-neutral-100 p-4 focus:border-black focus:outline-none transition-colors" />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold uppercase tracking-widest text-neutral-400">Project Goal</label>
              <select class="w-full bg-neutral-50 border-b-2 border-neutral-100 p-4 focus:border-black focus:outline-none transition-colors">
                 <option>Branding</option>
                 <option>Web Development</option>
                 <option>Mobile App</option>
                 <option>Strategy</option>
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold uppercase tracking-widest text-neutral-400">Message</label>
              <textarea rows="4" placeholder="Tell us about your project..." class="w-full bg-neutral-50 border-b-2 border-neutral-100 p-4 focus:border-black focus:outline-none transition-colors resize-none"></textarea>
            </div>
            <button class="w-full bg-black text-white p-6 rounded-2xl font-bold text-xl hover:bg-neutral-800 transition-all flex items-center justify-center gap-4">
              Send Message
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polyline points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </form>
        </FadeUp>
      </div>
    </div>
  </section>
</Layout>
