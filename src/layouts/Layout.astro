---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import SmoothScroll from '../components/animations/SmoothScroll';
import CustomCursor from '../components/animations/CustomCursor';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Premium Corporate Agency" } = Astro.props;

import Navbar from '../components/Navbar';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Innovate</title>
		<ClientRouter />
	</head>
	<body class="flex flex-col min-h-screen">
		<CustomCursor client:load />
		<SmoothScroll client:load>
			<Navbar client:load />

			<!-- Main Content -->
			<main class="flex-grow pt-20">
				<slot />
			</main>

			<!-- Minimalist Footer -->
			<footer class="bg-black text-white py-20 mt-auto">
				<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12">
					<div class="md:col-span-2">
						<h2 class="text-3xl font-bold mb-4 tracking-tight">Innovate.</h2>
						<p class="text-neutral-400 max-w-sm text-balance">
							Shaping the future of digital experiences through strategy, design, and technology.
						</p>
					</div>
					<div>
						<h4 class="font-semibold mb-4 text-neutral-300">Company</h4>
						<ul class="space-y-3">
							{navItems.map((item) => (
								<li>
									<a href={item.href} class="text-neutral-400 hover:text-white transition-colors">{item.name}</a>
								</li>
							))}
						</ul>
					</div>
					<div>
						<h4 class="font-semibold mb-4 text-neutral-300">Socials</h4>
						<ul class="space-y-3">
							<li><a href="#" class="text-neutral-400 hover:text-white transition-colors">LinkedIn</a></li>
							<li><a href="#" class="text-neutral-400 hover:text-white transition-colors">Twitter</a></li>
							<li><a href="#" class="text-neutral-400 hover:text-white transition-colors">Instagram</a></li>
						</ul>
					</div>
				</div>
				<div class="max-w-7xl mx-auto px-6 mt-16 pt-8 border-t border-neutral-800 flex flex-col md:flex-row items-center justify-between text-sm text-neutral-500">
					<p>&copy; {new Date().getFullYear()} Innovate. All rights reserved.</p>
					<div class="flex gap-4 mt-4 md:mt-0">
						<a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
						<a href="#" class="hover:text-white transition-colors">Terms of Service</a>
					</div>
				</div>
			</footer>
		</SmoothScroll>
	</body>
</html>

