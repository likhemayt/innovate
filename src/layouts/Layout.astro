---
import { ClientRouter } from 'astro:transitions';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/manrope/400.css';
import '@fontsource/manrope/500.css';
import '@fontsource/manrope/600.css';
import '@fontsource/manrope/700.css';
import '@fontsource/manrope/800.css';
import '../styles/global.css';
import SmoothScroll from '../components/animations/SmoothScroll';
import CustomCursor from '../components/animations/CustomCursor.astro';
import Navbar from '../components/Navbar';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Premium Corporate Agency" } = Astro.props;

const navItems = [
	{ name: 'Home', href: '/' },
	{ name: 'Services', href: '/services' },
	{ name: 'About', href: '/about' },
	{ name: 'Work', href: '/work' },
	{ name: 'Contact', href: '/contact' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Innovate</title>
		<ClientRouter />
		
		<!-- Canonical URL -->
		<link rel="canonical" href={Astro.url.href} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url.href} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL('/og-image.jpg', Astro.url)} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={Astro.url.href} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL('/og-image.jpg', Astro.url)} />

		<!-- Performance: early connection to image CDN -->
		<link rel="preconnect" href="https://images.unsplash.com" />
		<link rel="dns-prefetch" href="https://images.unsplash.com" />

		<slot name="head" />
		
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "ProfessionalService",
			"@id": "https://innovate-proto.vercel.app/#organization",
			"name": "Innovate",
			"url": "https://innovate-proto.vercel.app/",
			"foundingDate": "2018",
			"logo": {
				"@type": "ImageObject",
				"url": "https://innovate-proto.vercel.app/favicon.svg",
				"width": 64,
				"height": 64
			},
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "10 Anson Road, International Plaza",
				"addressLocality": "Singapore",
				"postalCode": "079903",
				"addressCountry": "SG"
			},
			"email": "hello@innovate.agency",
			"sameAs": [
				"https://linkedin.com/company/innovate",
				"https://twitter.com/innovate",
				"https://instagram.com/innovate"
			]
		}
		</script>
	</head>
	<body class="bg-[#fafafa] text-black selection:bg-black selection:text-white overflow-x-hidden flex flex-col min-h-screen">
		<div class="grain-overlay"></div>
		<CustomCursor />
		<Navbar client:idle />
		
		<SmoothScroll client:idle>
			<!-- Main Content -->
			<main class="flex-grow pt-20">
				<slot />
			</main>

			<!-- Minimalist Footer -->
			<footer class="bg-black text-white py-20 mt-auto">
				<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12">
					<div class="md:col-span-2">
						<h2 class="text-3xl font-bold mb-4 tracking-tight">Innovate.</h2>
						<p class="text-neutral-400 max-w-sm text-balance">
							Shaping the future of digital experiences through strategy, design, and technology.
						</p>
					</div>
					<div>
						<h4 class="font-semibold mb-4 text-neutral-300">Company</h4>
						<ul class="space-y-3">
							{navItems.map((item) => (
								<li>
									<a href={item.href} class="text-neutral-400 hover:text-white transition-colors">{item.name}</a>
								</li>
							))}
						</ul>
					</div>
					<div>
						<h4 class="font-semibold mb-4 text-neutral-300">Socials</h4>
						<ul class="space-y-3">
							<li><a href="https://linkedin.com/company/innovate" class="text-neutral-400 hover:text-white transition-colors">LinkedIn</a></li>
							<li><a href="https://twitter.com/innovate" class="text-neutral-400 hover:text-white transition-colors">Twitter</a></li>
							<li><a href="https://instagram.com/innovate" class="text-neutral-400 hover:text-white transition-colors">Instagram</a></li>
						</ul>
					</div>
				</div>
				<div class="max-w-7xl mx-auto px-6 mt-16 pt-8 border-t border-neutral-800 flex flex-col md:flex-row items-center justify-between text-sm text-neutral-500">
					<p>&copy; {new Date().getFullYear()} Innovate. All rights reserved.</p>
					<div class="flex gap-4 mt-4 md:mt-0">
						<a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
						<a href="/terms" class="hover:text-white transition-colors">Terms of Service</a>
					</div>
				</div>
			</footer>
			<!-- Global GSAP Scripts -->
			<script>
				import { gsap } from 'gsap';
				import { ScrollTrigger } from 'gsap/dist/ScrollTrigger';

				gsap.registerPlugin(ScrollTrigger);

				// Initialize Parallax & Reveals
				const initAnimations = () => {
					// Add FadeUp observer
					const observer = new IntersectionObserver((entries) => {
						entries.forEach(entry => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								observer.unobserve(entry.target);
							}
						});
					}, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
					
					document.querySelectorAll('.fade-up-element:not(.hero-fade-up)').forEach(el => observer.observe(el));

					// Kill previous ScrollTrigger instances to prevent duplicates on navigation
					ScrollTrigger.getAll().forEach(t => t.kill());
					// Image Reveals
					const reveals = document.querySelectorAll('[data-reveal="image"]');
					reveals.forEach((container) => {
						const img = container.querySelector('img');
						if (!img) return;

						gsap.set(img, { scale: 1.3, yPercent: 20 });
						
						gsap.to(img, {
							yPercent: -20,
							ease: "none",
							scrollTrigger: {
								trigger: container,
								start: "top bottom",
								end: "bottom top",
								scrub: true
							}
						});
					});

					// Standard Parallax
					const images = document.querySelectorAll('[data-parallax]');
					images.forEach((img) => {
						const speed = img.getAttribute('data-parallax') || "0.2";
						gsap.to(img, {
							yPercent: 10 * parseFloat(speed),
							ease: "none",
							scrollTrigger: {
								trigger: img,
								start: "top bottom",
								end: "bottom top",
								scrub: true
							}
						});
					});
					// Ambient Background Transitions
					const sections = document.querySelectorAll('[data-bgcolor]');
					sections.forEach((section) => {
						const color = section.getAttribute('data-bgcolor');
						if (!color) return;

						ScrollTrigger.create({
							trigger: section,
							start: "top 50%",
							end: "bottom 50%",
							onEnter: () => {
								gsap.to("body", { backgroundColor: color, duration: 1, ease: "power2.inOut" });
								if (color === "#000000" || color === "#111111") {
									document.body.classList.add('theme-dark');
								} else {
									document.body.classList.remove('theme-dark');
								}
							},
							onEnterBack: () => {
								gsap.to("body", { backgroundColor: color, duration: 1, ease: "power2.inOut" });
								if (color === "#000000" || color === "#111111") {
									document.body.classList.add('theme-dark');
								} else {
									document.body.classList.remove('theme-dark');
								}
							},
						});
					});
				};

				// Run on load and after transitions
				document.addEventListener('astro:page-load', initAnimations);
			</script>
		</SmoothScroll>
	</body>
</html>
