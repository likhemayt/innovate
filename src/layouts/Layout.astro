---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Premium Corporate Agency" } = Astro.props;

const navItems = [
	{ name: 'Home', href: '/' },
	{ name: 'Services', href: '/services' },
	{ name: 'About', href: '/about' },
	{ name: 'Work', href: '/work' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Innovate</title>
		<ClientRouter />
	</head>
	<body class="flex flex-col min-h-screen">
		<!-- Sticky Glass Navbar -->
		<header class="fixed top-0 left-0 right-0 z-50 glass-nav transition-all duration-300">
			<div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
				<!-- Logo -->
				<a href="/" class="text-xl font-bold tracking-tighter uppercase">
					Innovate<span class="text-neutral-400">.</span>
				</a>

				<!-- Desktop Nav -->
				<nav class="hidden md:flex items-center gap-8">
					{navItems.map((item) => (
						<a 
							href={item.href} 
							class="text-sm font-medium text-neutral-600 hover:text-black transition-colors"
						>
							{item.name}
						</a>
					))}
				</nav>

				<!-- CTA -->
				<div class="flex items-center gap-4">
					<a 
						href="/contact" 
						class="hidden md:inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-white bg-black rounded-full hover:bg-neutral-800 transition-colors"
					>
						Get in touch
					</a>
					<button class="md:hidden p-2 text-black">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
					</button>
				</div>
			</div>
		</header>

		<!-- Main Content -->
		<main class="flex-grow pt-20">
			<slot />
		</main>

		<!-- Minimalist Footer -->
		<footer class="bg-black text-white py-20 mt-auto">
			<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12">
				<div class="md:col-span-2">
					<h2 class="text-3xl font-bold mb-4 tracking-tight">Innovate.</h2>
					<p class="text-neutral-400 max-w-sm text-balance">
						Shaping the future of digital experiences through strategy, design, and technology.
					</p>
				</div>
				<div>
					<h4 class="font-semibold mb-4 text-neutral-300">Company</h4>
					<ul class="space-y-3">
						{navItems.map((item) => (
							<li>
								<a href={item.href} class="text-neutral-400 hover:text-white transition-colors">{item.name}</a>
							</li>
						))}
					</ul>
				</div>
				<div>
					<h4 class="font-semibold mb-4 text-neutral-300">Socials</h4>
					<ul class="space-y-3">
						<li><a href="#" class="text-neutral-400 hover:text-white transition-colors">LinkedIn</a></li>
						<li><a href="#" class="text-neutral-400 hover:text-white transition-colors">Twitter</a></li>
						<li><a href="#" class="text-neutral-400 hover:text-white transition-colors">Instagram</a></li>
					</ul>
				</div>
			</div>
			<div class="max-w-7xl mx-auto px-6 mt-16 pt-8 border-t border-neutral-800 flex flex-col md:flex-row items-center justify-between text-sm text-neutral-500">
				<p>&copy; {new Date().getFullYear()} Innovate. All rights reserved.</p>
				<div class="flex gap-4 mt-4 md:mt-0">
					<a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
					<a href="#" class="hover:text-white transition-colors">Terms of Service</a>
				</div>
			</div>
		</footer>
	</body>
</html>
